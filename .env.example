# Clé API OpenAI — requise pour la synthèse IA complète
# Sans cette clé, Limo utilise un mode fallback (extrait RSS brut)
OPENAI_API_KEY=

# Secret pour protéger l'endpoint /api/ingest (requis en production)
CRON_SECRET=changez-moi-en-production

# Vercel Blob — ajouté automatiquement quand vous créez un Blob Store sur Vercel
BLOB_READ_WRITE_TOKEN=
